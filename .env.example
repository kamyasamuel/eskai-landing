# ─── Eskai Landing — Environment Variables ──────────────────────────────────
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
# Path to SQLite database file (relative to project root).
# Default: data/eskai.db
# DB_PATH=data/eskai.db

# ── Security ─────────────────────────────────────────────────────────────────
# JWT secret key used to sign admin auth tokens.
# Generate one: openssl rand -base64 32
# WARNING: Change this in production! The dev default is a known string.
JWT_SECRET=your-256-bit-secret-change-in-production

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Next.js server listens on.
# Default: 3000
# PORT=3000

# ── Node Environment ─────────────────────────────────────────────────────────
# NODE_ENV=development